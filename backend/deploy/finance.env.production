# Finance API production environment
# Copy this file to EC2 as: /etc/finance/finance.env

# ---------- App ----------
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
SPRING_APPLICATION_NAME=finance

# ---------- Database (Amazon RDS PostgreSQL) ----------
SPRING_DATASOURCE_URL=jdbc:postgresql://finance-db.XXXXXXXXX.us-east-1.rds.amazonaws.com:5432/finance_db
SPRING_DATASOURCE_USERNAME=finance_app_user
SPRING_DATASOURCE_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# ---------- JPA / Hibernate ----------
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_JDBC_BATCH_SIZE=50
SPRING_JPA_PROPERTIES_HIBERNATE_ORDER_INSERTS=true
SPRING_JPA_PROPERTIES_HIBERNATE_ORDER_UPDATES=true

# ---------- Connection pool (HikariCP) ----------
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=20
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=5
SPRING_DATASOURCE_HIKARI_IDLE_TIMEOUT=300000
SPRING_DATASOURCE_HIKARI_MAX_LIFETIME=1800000
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000

# ---------- Logging ----------
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_ZOVRYN_FINANCE=INFO

# ---------- CORS (optional for web clients) ----------
# Example: https://app.yourdomain.com
APP_CORS_ALLOWED_ORIGINS=*
